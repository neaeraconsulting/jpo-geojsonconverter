{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$defs" : {
    "ProcessedPersonalDeviceUserType" : {
      "type" : "string",
      "enum" : [ "UNAVAILABLE", "APEDESTRIAN", "APEDALCYCLIST", "APUBLICSAFETYWORKER", "ANANIMAL" ]
    },
    "ProcessedValidationMessage" : {
      "type" : "object",
      "properties" : {
        "exception" : {
          "type" : "string"
        },
        "jsonPath" : {
          "type" : "string"
        },
        "message" : {
          "type" : "string"
        },
        "schemaPath" : {
          "type" : "string"
        }
      }
    },
    "PsmProperties" : {
      "type" : "object",
      "properties" : {
        "asn1" : {
          "type" : "string"
        },
        "basicType" : {
          "$ref" : "#/$defs/ProcessedPersonalDeviceUserType"
        },
        "heading" : {
          "type" : "number",
          "format" : "double"
        },
        "id" : {
          "type" : "string"
        },
        "messageType" : {
          "type" : "string"
        },
        "msgCnt" : {
          "type" : "integer",
          "format" : "int32"
        },
        "odeReceivedAt" : {
          "type" : "string"
        },
        "originIp" : {
          "type" : "string"
        },
        "schemaVersion" : {
          "type" : "integer",
          "format" : "int32"
        },
        "secMark" : {
          "type" : "integer",
          "format" : "int32"
        },
        "speed" : {
          "type" : "number",
          "format" : "double"
        },
        "timeStamp" : {
          "type" : "string",
          "format" : "date-time"
        },
        "validationMessages" : {
          "type" : "array",
          "items" : {
            "$ref" : "#/$defs/ProcessedValidationMessage"
          }
        }
      }
    }
  },
  "type" : "object",
  "properties" : {
    "geometry" : { },
    "id" : {
      "type" : "integer",
      "format" : "int32"
    },
    "properties" : {
      "$ref" : "#/$defs/PsmProperties"
    }
  }
}