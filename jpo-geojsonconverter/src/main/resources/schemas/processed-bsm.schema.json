{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$defs" : {
    "BsmProperties" : {
      "type" : "object",
      "properties" : {
        "accelSet" : {
          "$ref" : "#/$defs/ProcessedBsmAccelerationSet4Way"
        },
        "accuracy" : {
          "$ref" : "#/$defs/ProcessedBsmPositionalAccuracy"
        },
        "angle" : {
          "type" : "number",
          "format" : "double"
        },
        "asn1" : {
          "type" : "string"
        },
        "brakes" : {
          "$ref" : "#/$defs/ProcessedBrakeSystemStatus"
        },
        "heading" : {
          "type" : "number",
          "format" : "double"
        },
        "id" : {
          "type" : "string"
        },
        "logName" : {
          "type" : "string"
        },
        "messageType" : {
          "type" : "string"
        },
        "msgCnt" : {
          "type" : "integer",
          "format" : "int32"
        },
        "odeReceivedAt" : {
          "type" : "string"
        },
        "originIp" : {
          "type" : "string"
        },
        "schemaVersion" : {
          "type" : "integer",
          "format" : "int32"
        },
        "secMark" : {
          "type" : "integer",
          "format" : "int32"
        },
        "size" : {
          "$ref" : "#/$defs/ProcessedVehicleSize"
        },
        "speed" : {
          "type" : "number",
          "format" : "double"
        },
        "timeStamp" : {
          "type" : "string",
          "format" : "date-time"
        },
        "transmission" : {
          "$ref" : "#/$defs/ProcessedTransmissionState"
        },
        "validationMessages" : {
          "type" : "array",
          "items" : {
            "$ref" : "#/$defs/ProcessedValidationMessage"
          }
        }
      }
    },
    "ProcessedAntiLockBrakeStatus" : {
      "type" : "string",
      "enum" : [ "UNAVAILABLE", "OFF", "ON", "ENGAGED" ]
    },
    "ProcessedAuxiliaryBrakeStatus" : {
      "type" : "string",
      "enum" : [ "UNAVAILABLE", "OFF", "ON", "RESERVED" ]
    },
    "ProcessedBrakeAppliedStatus" : {
      "type" : "object"
    },
    "ProcessedBrakeBoostApplied" : {
      "type" : "string",
      "enum" : [ "UNAVAILABLE", "OFF", "ON" ]
    },
    "ProcessedBrakeSystemStatus" : {
      "type" : "object",
      "properties" : {
        "abs" : {
          "$ref" : "#/$defs/ProcessedAntiLockBrakeStatus"
        },
        "auxBrakes" : {
          "$ref" : "#/$defs/ProcessedAuxiliaryBrakeStatus"
        },
        "brakeBoost" : {
          "$ref" : "#/$defs/ProcessedBrakeBoostApplied"
        },
        "scs" : {
          "$ref" : "#/$defs/ProcessedStabilityControlStatus"
        },
        "traction" : {
          "$ref" : "#/$defs/ProcessedTractionControlStatus"
        },
        "wheelBrakes" : {
          "$ref" : "#/$defs/ProcessedBrakeAppliedStatus"
        }
      }
    },
    "ProcessedBsmAccelerationSet4Way" : {
      "type" : "object",
      "properties" : {
        "accelLat" : {
          "type" : "number",
          "format" : "double"
        },
        "accelLong" : {
          "type" : "number",
          "format" : "double"
        },
        "accelVert" : {
          "type" : "number",
          "format" : "double"
        },
        "accelYaw" : {
          "type" : "number",
          "format" : "double"
        }
      }
    },
    "ProcessedBsmPositionalAccuracy" : {
      "type" : "object",
      "properties" : {
        "orientation" : {
          "type" : "number",
          "format" : "double"
        },
        "semiMajor" : {
          "type" : "number",
          "format" : "double"
        },
        "semiMinor" : {
          "type" : "number",
          "format" : "double"
        }
      }
    },
    "ProcessedStabilityControlStatus" : {
      "type" : "string",
      "enum" : [ "UNAVAILABLE", "OFF", "ON", "ENGAGED" ]
    },
    "ProcessedTractionControlStatus" : {
      "type" : "string",
      "enum" : [ "UNAVAILABLE", "OFF", "ON", "ENGAGED" ]
    },
    "ProcessedTransmissionState" : {
      "type" : "string",
      "enum" : [ "NEUTRAL", "PARK", "FORWARDGEARS", "REVERSEGEARS", "RESERVED1", "RESERVED2", "RESERVED3", "UNAVAILABLE" ]
    },
    "ProcessedValidationMessage" : {
      "type" : "object",
      "properties" : {
        "exception" : {
          "type" : "string"
        },
        "jsonPath" : {
          "type" : "string"
        },
        "message" : {
          "type" : "string"
        },
        "schemaPath" : {
          "type" : "string"
        }
      }
    },
    "ProcessedVehicleSize" : {
      "type" : "object",
      "properties" : {
        "length" : {
          "type" : "integer",
          "format" : "int32"
        },
        "width" : {
          "type" : "integer",
          "format" : "int32"
        }
      }
    }
  },
  "type" : "object",
  "properties" : {
    "geometry" : { },
    "id" : {
      "type" : "integer",
      "format" : "int32"
    },
    "properties" : {
      "$ref" : "#/$defs/BsmProperties"
    }
  }
}