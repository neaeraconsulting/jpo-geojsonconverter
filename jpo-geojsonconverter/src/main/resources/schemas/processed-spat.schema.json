{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$defs" : {
    "ProcessedAdvisorySpeed" : {
      "type" : "object",
      "properties" : {
        "class" : {
          "type" : "integer",
          "format" : "int32"
        },
        "confidence" : {
          "$ref" : "#/$defs/ProcessedSpeedConfidence"
        },
        "distance" : {
          "type" : "integer",
          "format" : "int32"
        },
        "speed" : {
          "type" : "integer",
          "format" : "int32"
        },
        "type" : {
          "$ref" : "#/$defs/ProcessedAdvisorySpeedType"
        },
        "class()" : {
          "type" : "integer",
          "format" : "int32"
        }
      }
    },
    "ProcessedAdvisorySpeedType" : {
      "type" : "string",
      "enum" : [ "NONE", "GREENWAVE", "ECODRIVE", "TRANSIT" ]
    },
    "ProcessedIntersectionStatusObject" : {
      "type" : "object"
    },
    "ProcessedMovementEvent" : {
      "type" : "object",
      "properties" : {
        "eventState" : {
          "$ref" : "#/$defs/ProcessedMovementPhaseState"
        },
        "speeds" : {
          "type" : "array",
          "items" : {
            "$ref" : "#/$defs/ProcessedAdvisorySpeed"
          }
        },
        "timing" : {
          "$ref" : "#/$defs/TimingChangeDetails"
        }
      }
    },
    "ProcessedMovementPhaseState" : {
      "type" : "string",
      "enum" : [ "UNAVAILABLE", "DARK", "STOP_THEN_PROCEED", "STOP_AND_REMAIN", "PRE_MOVEMENT", "PERMISSIVE_MOVEMENT_ALLOWED", "PROTECTED_MOVEMENT_ALLOWED", "PERMISSIVE_CLEARANCE", "PROTECTED_CLEARANCE", "CAUTION_CONFLICTING_TRAFFIC" ]
    },
    "ProcessedMovementState" : {
      "type" : "object",
      "properties" : {
        "movementName" : {
          "type" : "string"
        },
        "signalGroup" : {
          "type" : "integer",
          "format" : "int32"
        },
        "stateTimeSpeed" : {
          "type" : "array",
          "items" : {
            "$ref" : "#/$defs/ProcessedMovementEvent"
          }
        }
      }
    },
    "ProcessedSpeedConfidence" : {
      "type" : "string",
      "enum" : [ "UNAVAILABLE", "PREC100MS", "PREC10MS", "PREC5MS", "PREC1MS", "PREC0_1MS", "PREC0_05MS", "PREC0_01MS" ]
    },
    "ProcessedValidationMessage" : {
      "type" : "object",
      "properties" : {
        "exception" : {
          "type" : "string"
        },
        "jsonPath" : {
          "type" : "string"
        },
        "message" : {
          "type" : "string"
        },
        "schemaPath" : {
          "type" : "string"
        }
      }
    },
    "TimingChangeDetails" : {
      "type" : "object",
      "properties" : {
        "confidence" : {
          "type" : "integer",
          "format" : "int32"
        },
        "likelyTime" : {
          "type" : "string",
          "format" : "date-time"
        },
        "maxEndTime" : {
          "type" : "string",
          "format" : "date-time"
        },
        "minEndTime" : {
          "type" : "string",
          "format" : "date-time"
        },
        "nextTime" : {
          "type" : "string",
          "format" : "date-time"
        },
        "startTime" : {
          "type" : "string",
          "format" : "date-time"
        }
      }
    }
  },
  "type" : "object",
  "properties" : {
    "asn1" : {
      "type" : "string"
    },
    "cti4501Conformant" : {
      "type" : "boolean"
    },
    "enabledLanes" : {
      "type" : "array",
      "items" : {
        "type" : "integer",
        "format" : "int32"
      }
    },
    "intersectionId" : {
      "type" : "integer",
      "format" : "int32"
    },
    "messageType" : {
      "type" : "string"
    },
    "name" : {
      "type" : "string"
    },
    "odeReceivedAt" : {
      "type" : "string"
    },
    "originIp" : {
      "type" : "string"
    },
    "region" : {
      "type" : "integer",
      "format" : "int32"
    },
    "revision" : {
      "type" : "integer",
      "format" : "int32"
    },
    "schemaVersion" : {
      "type" : "integer",
      "format" : "int32"
    },
    "states" : {
      "type" : "array",
      "items" : {
        "$ref" : "#/$defs/ProcessedMovementState"
      }
    },
    "status" : {
      "$ref" : "#/$defs/ProcessedIntersectionStatusObject"
    },
    "utcTimeStamp" : {
      "type" : "string",
      "format" : "date-time"
    },
    "validationMessages" : {
      "type" : "array",
      "items" : {
        "$ref" : "#/$defs/ProcessedValidationMessage"
      }
    },
    "utcTimeStampTS" : {
      "type" : "string",
      "format" : "date-time"
    }
  }
}