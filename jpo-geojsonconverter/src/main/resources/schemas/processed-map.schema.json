{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "$defs" : {
    "ConnectingLanesFeature(Object)" : {
      "type" : "object",
      "properties" : {
        "geometry" : { },
        "id" : {
          "type" : "string"
        },
        "properties" : {
          "$ref" : "#/$defs/ConnectingLanesProperties"
        }
      }
    },
    "ConnectingLanesFeatureCollection(Object)" : {
      "type" : "object",
      "properties" : {
        "features" : {
          "type" : "array",
          "items" : {
            "$ref" : "#/$defs/ConnectingLanesFeature(Object)"
          }
        }
      }
    },
    "ConnectingLanesProperties" : {
      "type" : "object",
      "properties" : {
        "egressLaneId" : {
          "type" : "integer",
          "format" : "int32"
        },
        "ingressLaneId" : {
          "type" : "integer",
          "format" : "int32"
        },
        "signalGroupId" : {
          "type" : "integer",
          "format" : "int32"
        }
      }
    },
    "MapFeature(Object)" : {
      "type" : "object",
      "properties" : {
        "geometry" : { },
        "id" : {
          "type" : "integer",
          "format" : "int32"
        },
        "properties" : {
          "$ref" : "#/$defs/MapProperties"
        }
      }
    },
    "MapFeatureCollection(Object)" : {
      "type" : "object",
      "properties" : {
        "features" : {
          "type" : "array",
          "items" : {
            "$ref" : "#/$defs/MapFeature(Object)"
          }
        }
      }
    },
    "MapNode" : {
      "type" : "object",
      "properties" : {
        "delta" : {
          "type" : "array",
          "items" : {
            "type" : "integer",
            "format" : "int32"
          }
        },
        "stopLine" : {
          "type" : "boolean"
        }
      }
    },
    "MapProperties" : {
      "type" : "object",
      "properties" : {
        "connectsTo" : {
          "type" : "array",
          "items" : {
            "$ref" : "#/$defs/ProcessedConnection"
          }
        },
        "egressApproach" : {
          "type" : "integer",
          "format" : "int32"
        },
        "egressPath" : {
          "type" : "boolean"
        },
        "ingressApproach" : {
          "type" : "integer",
          "format" : "int32"
        },
        "ingressPath" : {
          "type" : "boolean"
        },
        "laneId" : {
          "type" : "integer",
          "format" : "int32"
        },
        "laneName" : {
          "type" : "string"
        },
        "laneType" : {
          "$ref" : "#/$defs/ProcessedLaneTypeAttributes"
        },
        "maneuvers" : {
          "$ref" : "#/$defs/ProcessedAllowedManeuvers"
        },
        "nodes" : {
          "type" : "array",
          "items" : {
            "$ref" : "#/$defs/MapNode"
          }
        },
        "sharedWith" : {
          "$ref" : "#/$defs/ProcessedLaneSharing"
        }
      }
    },
    "MapRefPoint" : {
      "type" : "object",
      "properties" : {
        "elevation" : {
          "type" : "number",
          "format" : "double"
        },
        "latitude" : {
          "type" : "number",
          "format" : "double"
        },
        "longitude" : {
          "type" : "number",
          "format" : "double"
        }
      }
    },
    "MapSharedProperties" : {
      "type" : "object",
      "properties" : {
        "asn1" : {
          "type" : "string"
        },
        "cti4501Conformant" : {
          "type" : "boolean"
        },
        "intersectionId" : {
          "type" : "integer",
          "format" : "int32"
        },
        "intersectionName" : {
          "type" : "string"
        },
        "laneWidth" : {
          "type" : "integer",
          "format" : "int32"
        },
        "mapSource" : {
          "$ref" : "#/$defs/Source"
        },
        "messageType" : {
          "type" : "string"
        },
        "msgIssueRevision" : {
          "type" : "integer",
          "format" : "int32"
        },
        "odeReceivedAt" : {
          "type" : "string",
          "format" : "date-time"
        },
        "originIp" : {
          "type" : "string"
        },
        "refPoint" : {
          "$ref" : "#/$defs/MapRefPoint"
        },
        "region" : {
          "type" : "integer",
          "format" : "int32"
        },
        "revision" : {
          "type" : "integer",
          "format" : "int32"
        },
        "schemaVersion" : {
          "type" : "integer",
          "format" : "int32"
        },
        "speedLimits" : {
          "type" : "array",
          "items" : {
            "$ref" : "#/$defs/ProcessedRegulatorySpeedLimit"
          }
        },
        "timeStamp" : {
          "type" : "string",
          "format" : "date-time"
        },
        "validationMessages" : {
          "type" : "array",
          "items" : {
            "$ref" : "#/$defs/ProcessedValidationMessage"
          }
        }
      }
    },
    "ProcessedAllowedManeuvers" : {
      "type" : "object"
    },
    "ProcessedConnectingLane" : {
      "type" : "object",
      "properties" : {
        "lane" : {
          "type" : "integer",
          "format" : "int32"
        },
        "maneuver" : {
          "$ref" : "#/$defs/ProcessedAllowedManeuvers"
        }
      }
    },
    "ProcessedConnection" : {
      "type" : "object",
      "properties" : {
        "connectingLane" : {
          "$ref" : "#/$defs/ProcessedConnectingLane"
        },
        "connectionID" : {
          "type" : "integer",
          "format" : "int32"
        },
        "remoteIntersection" : {
          "$ref" : "#/$defs/ProcessedIntersectionReferenceID"
        },
        "signalGroup" : {
          "type" : "integer",
          "format" : "int32"
        },
        "userClass" : {
          "type" : "integer",
          "format" : "int32"
        }
      }
    },
    "ProcessedIntersectionReferenceID" : {
      "type" : "object",
      "properties" : {
        "id" : {
          "type" : "integer",
          "format" : "int32"
        },
        "region" : {
          "type" : "integer",
          "format" : "int32"
        }
      }
    },
    "ProcessedLaneAttributes_Barrier" : {
      "type" : "object"
    },
    "ProcessedLaneAttributes_Bike" : {
      "type" : "object"
    },
    "ProcessedLaneAttributes_Crosswalk" : {
      "type" : "object"
    },
    "ProcessedLaneAttributes_Parking" : {
      "type" : "object"
    },
    "ProcessedLaneAttributes_Sidewalk" : {
      "type" : "object"
    },
    "ProcessedLaneAttributes_Striping" : {
      "type" : "object"
    },
    "ProcessedLaneAttributes_TrackedVehicle" : {
      "type" : "object"
    },
    "ProcessedLaneAttributes_Vehicle" : {
      "type" : "object"
    },
    "ProcessedLaneSharing" : {
      "type" : "object"
    },
    "ProcessedLaneTypeAttributes" : {
      "type" : "object",
      "properties" : {
        "bikeLane" : {
          "$ref" : "#/$defs/ProcessedLaneAttributes_Bike"
        },
        "crosswalk" : {
          "$ref" : "#/$defs/ProcessedLaneAttributes_Crosswalk"
        },
        "median" : {
          "$ref" : "#/$defs/ProcessedLaneAttributes_Barrier"
        },
        "parking" : {
          "$ref" : "#/$defs/ProcessedLaneAttributes_Parking"
        },
        "sidewalk" : {
          "$ref" : "#/$defs/ProcessedLaneAttributes_Sidewalk"
        },
        "striping" : {
          "$ref" : "#/$defs/ProcessedLaneAttributes_Striping"
        },
        "trackedVehicle" : {
          "$ref" : "#/$defs/ProcessedLaneAttributes_TrackedVehicle"
        },
        "vehicle" : {
          "$ref" : "#/$defs/ProcessedLaneAttributes_Vehicle"
        }
      }
    },
    "ProcessedRegulatorySpeedLimit" : {
      "type" : "object",
      "properties" : {
        "speed" : {
          "type" : "integer",
          "format" : "int32"
        },
        "type" : {
          "$ref" : "#/$defs/ProcessedSpeedLimitType"
        }
      }
    },
    "ProcessedSpeedLimitType" : {
      "type" : "string",
      "enum" : [ "UNKNOWN", "MAXSPEEDINSCHOOLZONE", "MAXSPEEDINSCHOOLZONEWHENCHILDRENAREPRESENT", "MAXSPEEDINCONSTRUCTIONZONE", "VEHICLEMINSPEED", "VEHICLEMAXSPEED", "VEHICLENIGHTMAXSPEED", "TRUCKMINSPEED", "TRUCKMAXSPEED", "TRUCKNIGHTMAXSPEED", "VEHICLESWITHTRAILERSMINSPEED", "VEHICLESWITHTRAILERSMAXSPEED", "VEHICLESWITHTRAILERSNIGHTMAXSPEED" ]
    },
    "ProcessedValidationMessage" : {
      "type" : "object",
      "properties" : {
        "exception" : {
          "type" : "string"
        },
        "jsonPath" : {
          "type" : "string"
        },
        "message" : {
          "type" : "string"
        },
        "schemaPath" : {
          "type" : "string"
        }
      }
    },
    "Source" : {
      "type" : "string",
      "enum" : [ "RSU", "V2X", "MMITSS", "EV", "RV", "SAT", "SNMP", "NA", "UNKNOWN" ]
    }
  },
  "type" : "object",
  "properties" : {
    "connectingLanesFeatureCollection" : {
      "$ref" : "#/$defs/ConnectingLanesFeatureCollection(Object)"
    },
    "mapFeatureCollection" : {
      "$ref" : "#/$defs/MapFeatureCollection(Object)"
    },
    "properties" : {
      "$ref" : "#/$defs/MapSharedProperties"
    }
  }
}